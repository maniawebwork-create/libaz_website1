generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  title       String
  description String
  price       String
  oldPrice    String?
  mainImage   String
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  products  Product[]
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., 'hero_banner_1', 'footer_phone'
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  authorName String
  rating     Int      @default(5)
  content    String
  createdAt  DateTime @default(now())
}

model StoreLocation {
  id        String   @id @default(cuid())
  title     String
  address   String
  mapUrl    String
  createdAt DateTime @default(now())
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  content   String
  image     String?
  date      DateTime @default(now())
}
